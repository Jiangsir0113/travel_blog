---
import type { CityFootprint } from "../../lib/map-data";

interface Props {
  footprints: CityFootprint[];
}

const { footprints } = Astro.props;

function markerRadius(tripCount: number) {
  return Math.min(17, 8 + tripCount * 2);
}
---

<div class="footprint-map" aria-labelledby="footprint-map-title">
  <h3 id="footprint-map-title" class="sr-only">中国城市足迹图</h3>
  <p id="footprint-map-desc" class="sr-only">地图上标记已发布游记覆盖的城市，并用作者颜色区分足迹。</p>

  <div class="footprint-canvas">
    <div
      class="china-map-stage"
      role="img"
      aria-labelledby="footprint-map-title footprint-map-desc"
    >
      <img class="china-map-image" src="/maps/china-map.jpg" alt="" loading="lazy" />
      <div class="map-marker-layer">
        {
          footprints.map((footprint) => {
            const radius = markerRadius(footprint.trips.length);
            const color = footprint.authorColors[0] ?? "#2f6f7b";
            const firstTrip = footprint.trips[0];

            return (
              <a
                href={firstTrip ? `/trips/${firstTrip.slug}/` : "#"}
                class="map-marker"
                aria-label={`${footprint.city}，${footprint.trips.length} 篇游记`}
                style={`--marker-x: ${footprint.x}%; --marker-y: ${footprint.y}%; --marker-color: ${color}; --marker-size: ${radius * 2}px;`}
              >
                <span class="map-marker-halo" aria-hidden="true"></span>
                <span class="map-marker-dot" aria-hidden="true"></span>
                <span class="map-marker-label">{footprint.city}</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>

  <div class="footprint-city-grid" aria-label="城市游记列表">
    {
      footprints.map((footprint) => (
        <article class="footprint-card">
          <div class="footprint-card-header">
            <div>
              <p class="meta">
                {footprint.isFallbackLocation ? "位置待校准" : "城市足迹"} ·{" "}
                {footprint.trips.length} 篇
              </p>
              <h3>{footprint.city}</h3>
            </div>
            <div class="author-swatch-list" aria-label="作者颜色">
              {footprint.authorColors.map((color) => (
                <span class="author-swatch" style={`--swatch-color: ${color}`}></span>
              ))}
            </div>
          </div>

          <ul class="footprint-trip-list">
            {footprint.trips.map((trip) => (
              <li>
                <a href={`/trips/${trip.slug}/`}>{trip.title}</a>
                <span class="meta">
                  {trip.destinationName} · {trip.author.name}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</div>
