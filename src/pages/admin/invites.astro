---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { getSessionProfile } from "../../lib/auth";
import { isAdmin } from "../../lib/roles";

export const prerender = false;

const { supabase, user, profile } = await getSessionProfile(Astro);
if (!user) {
  return Astro.redirect(`/auth/login/?next=${encodeURIComponent(new URL(Astro.request.url).pathname)}`, 302);
}

if (!isAdmin(profile?.role)) {
  return Astro.redirect("/dashboard/", 302);
}

let message: string | null = null;
let error: string | null = null;

if (Astro.request.method === "POST") {
  const code = `invite-${crypto.randomUUID().replaceAll("-", "")}`;
  const { error: insertError } = await supabase.from("invite_codes").insert({
    code,
    role_to_grant: "author",
    max_uses: 10,
    created_by: profile?.id ?? user.id,
  });

  if (insertError) {
    error = "生成邀请码失败，请稍后再试。";
  } else {
    message = `已生成邀请码：${code}`;
  }
}

const { data: invites, error: loadError } = await supabase
  .from("invite_codes")
  .select("id, code, used_count, max_uses, is_active, created_at")
  .order("created_at", { ascending: false });
---

<DashboardLayout title="邀请码管理 - 旅行共写小站">
  <section class="section">
    <p class="eyebrow">管理</p>
    <h1>邀请码管理</h1>
    <p class="lead">新邀请码默认授予作者权限，最多可使用 10 次。</p>
    <form method="post" class="button-row">
      <button class="button" type="submit">生成新邀请码</button>
      <a class="button secondary" href="/admin/">返回管理后台</a>
    </form>
    {message && <p class="meta" role="status">{message}</p>}
    {error && <p class="meta" role="alert">{error}</p>}
  </section>

  <section class="section" aria-labelledby="invite-list">
    <h2 id="invite-list">邀请码列表</h2>
    {loadError && <p class="meta" role="alert">读取邀请码失败，请稍后再试。</p>}
    {
      !loadError && invites && invites.length > 0 ? (
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th scope="col">邀请码</th>
                <th scope="col">已使用</th>
                <th scope="col">上限</th>
                <th scope="col">启用</th>
              </tr>
            </thead>
            <tbody>
              {invites.map((invite) => (
                <tr>
                  <td>
                    <code>{invite.code}</code>
                  </td>
                  <td>{invite.used_count}</td>
                  <td>{invite.max_uses}</td>
                  <td>{invite.is_active ? "是" : "否"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        !loadError && <p class="meta">还没有邀请码。</p>
      )
    }
  </section>
</DashboardLayout>
