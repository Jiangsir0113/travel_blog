---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSessionProfile } from "../../lib/auth";

export const prerender = false;

const { user, profile } = await getSessionProfile(Astro);

if (user && profile) {
  return Astro.redirect("/dashboard/", 302);
}
---

<BaseLayout
  title="登录 - 旅行共写小站"
  description="登录旅行共写小站后查看游记、足迹图和个人空间。"
  variant="auth"
>
  <section class="auth-shell">
    <div class="auth-visual" aria-hidden="true">
      <img src="/images/login-travel-bg.svg" alt="" />
    </div>

    <div class="auth-card">
      <a class="auth-brand" href="/auth/login/">旅行共写小站</a>
      <p class="eyebrow">朋友入口</p>
      <h1>先登录，再一起翻开旅程。</h1>
      <p class="lead">
        游记、照片和足迹图只对小站成员开放。用你的用户名和密码进入个人空间。
      </p>

      <form id="login-form" class="auth-form" novalidate>
        <div class="field">
          <label for="login-id">用户名</label>
          <input
            id="login-id"
            name="loginId"
            autocomplete="username"
            placeholder="例如 yanshuo"
            required
          />
        </div>

        <div class="field">
          <label for="password">密码</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            placeholder="输入密码"
            required
          />
        </div>

        <div class="button-row">
          <button class="button" type="submit">登录小站</button>
          <a class="button secondary" href="/auth/register/">注册账号</a>
        </div>

        <p id="login-message" class="meta auth-message" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  import { createSupabaseBrowserClient } from "../../lib/supabase/browser";
  import { identifierToAuthEmail } from "../../lib/username-auth";

  const form = document.querySelector<HTMLFormElement>("#login-form");
  const message = document.querySelector<HTMLParagraphElement>("#login-message");

  function showMessage(text: string) {
    if (message) {
      message.textContent = text;
    }
  }

  function getSafeNextPath() {
    const next = new URLSearchParams(window.location.search).get("next");

    if (!next || !next.startsWith("/") || next.startsWith("//")) {
      return "/dashboard/";
    }

    try {
      const parsed = new URL(next, window.location.origin);

      if (parsed.origin !== window.location.origin) {
        return "/dashboard/";
      }

      return `${parsed.pathname}${parsed.search}${parsed.hash}`;
    } catch {
      return "/dashboard/";
    }
  }

  async function resolveLoginEmail(
    supabase: ReturnType<typeof createSupabaseBrowserClient>,
    loginId: string,
  ) {
    if (loginId.includes("@")) {
      return identifierToAuthEmail(loginId);
    }

    const { data, error } = await supabase.rpc("resolve_username_auth_email", {
      login_username: loginId,
    });

    if (!error && typeof data === "string" && data) {
      return data;
    }

    return identifierToAuthEmail(loginId);
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    showMessage("正在登录...");

    const formData = new FormData(form);
    const loginId = String(formData.get("loginId") ?? "").trim();
    const password = String(formData.get("password") ?? "");

    if (!loginId || !password) {
      showMessage("请填写用户名和密码。");
      return;
    }

    try {
      const supabase = createSupabaseBrowserClient();
      const email = await resolveLoginEmail(supabase, loginId);
      const { error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        showMessage("登录失败，请检查用户名和密码。");
        return;
      }

      window.location.assign(getSafeNextPath());
    } catch {
      showMessage("登录失败，请稍后再试。");
    }
  });
</script>
