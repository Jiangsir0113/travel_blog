---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout title="注册 - 旅行共写小站">
  <section class="section">
    <h1>注册</h1>
    <p class="lead">使用邀请码加入小站，和朋友一起记录旅程。</p>

    <form id="register-form" class="form-grid" novalidate>
      <div class="field">
        <label for="display-name">昵称</label>
        <input id="display-name" name="displayName" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="email">邮箱</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="password">密码</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          minlength="6"
          required
        />
      </div>

      <div class="field">
        <label for="invite-code">邀请码</label>
        <input id="invite-code" name="inviteCode" autocomplete="off" required />
      </div>

      <div class="button-row">
        <button class="button" type="submit">注册</button>
        <a class="button secondary" href="/auth/login/">已有账号，去登录</a>
      </div>

      <p id="register-message" class="meta" role="status" aria-live="polite"></p>
    </form>
  </section>
</BaseLayout>

<script>
  import { createSupabaseBrowserClient } from "../../lib/supabase/browser";

  const form = document.querySelector<HTMLFormElement>("#register-form");
  const message = document.querySelector<HTMLParagraphElement>("#register-message");

  function showMessage(text: string) {
    if (message) {
      message.textContent = text;
    }
  }

  function getRegisterError(errorMessage: string) {
    if (errorMessage.includes("INVITE_CODE_INVALID")) {
      return "邀请码无效、已过期或已被用完。";
    }

    if (errorMessage.includes("PROFILE_ALREADY_EXISTS")) {
      return "这个账号已经创建过个人资料，请直接登录。";
    }

    if (errorMessage.includes("DISPLAY_NAME_INVALID")) {
      return "昵称需要填写，且不能超过 60 个字符。";
    }

    if (errorMessage.includes("AUTH_REQUIRED")) {
      return "注册会话无效，请重新注册或登录后再试。";
    }

    if (
      errorMessage.toLowerCase().includes("already registered") ||
      errorMessage.toLowerCase().includes("already exists")
    ) {
      return "这个邮箱可能已经注册，请直接登录或换一个邮箱。";
    }

    return "注册失败，请检查邮箱、密码和邀请码后再试。";
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    showMessage("正在注册...");

    const formData = new FormData(form);
    const displayName = String(formData.get("displayName") ?? "").trim();
    const email = String(formData.get("email") ?? "").trim();
    const password = String(formData.get("password") ?? "");
    const inviteCode = String(formData.get("inviteCode") ?? "").trim();

    if (!displayName || !email || !password || !inviteCode) {
      showMessage("请填写昵称、邮箱、密码和邀请码。");
      return;
    }

    try {
      const supabase = createSupabaseBrowserClient();
      const {
        data: { session: currentSession },
      } = await supabase.auth.getSession();
      let activeSession =
        currentSession?.user.email?.toLowerCase() === email.toLowerCase()
          ? currentSession
          : null;

      if (currentSession && !activeSession) {
        const { error: signOutError } = await supabase.auth.signOut();

        if (signOutError) {
          showMessage("当前已有其他账号登录，请先退出后再注册。");
          return;
        }
      }

      if (!activeSession) {
        const { data, error: signUpError } = await supabase.auth.signUp({
          email,
          password,
        });

        if (signUpError) {
          showMessage(getRegisterError(signUpError.message));
          return;
        }

        activeSession = data.session;
      }

      if (!activeSession) {
        showMessage(
          "注册邮件已发送。当前环境需要先确认邮箱，暂时无法立即创建个人资料；请确认邮箱后登录，再联系管理员补发邀请码或完成资料创建。",
        );
        return;
      }

      const { error: profileError } = await supabase.rpc(
        "create_profile_with_invite",
        {
          invite_code: inviteCode,
          display_name: displayName,
          avatar_url: null,
        },
      );

      if (profileError) {
        showMessage(getRegisterError(profileError.message));
        return;
      }

      window.location.assign("/dashboard/");
    } catch (error) {
      showMessage(
        error instanceof Error
          ? getRegisterError(error.message)
          : "注册失败，请稍后再试。",
      );
    }
  });
</script>
