---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSessionProfile } from "../../lib/auth";

export const prerender = false;

const { user, profile } = await getSessionProfile(Astro);

if (user && profile) {
  return Astro.redirect("/dashboard/", 302);
}
---

<BaseLayout
  title="注册 - 旅行共写小站"
  description="用邀请码注册旅行共写小站账号。"
  variant="auth"
>
  <section class="auth-shell">
    <div class="auth-visual" aria-hidden="true">
      <img src="/images/login-travel-bg.svg" alt="" />
    </div>

    <div class="auth-card">
      <a class="auth-brand" href="/auth/login/">旅行共写小站</a>
      <p class="eyebrow">邀请加入</p>
      <h1>拿到邀请码，就可以开始写旅行。</h1>
      <p class="lead">
        注册后可以发布自己的游记，也能查看朋友们已经点亮的城市足迹。
      </p>

      <form id="register-form" class="auth-form" novalidate>
        <div class="field">
          <label for="username">用户名</label>
          <input
            id="username"
            name="username"
            autocomplete="username"
            minlength="3"
            maxlength="24"
            pattern="[a-z0-9_]{3,24}"
            placeholder="3-24 位小写字母、数字或下划线"
            required
          />
        </div>

        <div class="field">
          <label for="password">密码</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="new-password"
            minlength="6"
            placeholder="至少 6 位"
            required
          />
        </div>

        <div class="field">
          <label for="invite-code">邀请码</label>
          <input
            id="invite-code"
            name="inviteCode"
            autocomplete="off"
            placeholder="向管理员获取"
            required
          />
        </div>

        <div class="button-row">
          <button class="button" type="submit">注册并进入</button>
          <a class="button secondary" href="/auth/login/">返回登录</a>
        </div>

        <p id="register-message" class="meta auth-message" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  import { createSupabaseBrowserClient } from "../../lib/supabase/browser";
  import {
    getUsernameHelpText,
    isValidUsername,
    normalizeUsername,
    usernameToAuthEmail,
  } from "../../lib/username-auth";

  const form = document.querySelector<HTMLFormElement>("#register-form");
  const message = document.querySelector<HTMLParagraphElement>("#register-message");

  function showMessage(text: string) {
    if (message) {
      message.textContent = text;
    }
  }

  function getRegisterError(errorMessage: string) {
    if (errorMessage.includes("INVITE_CODE_INVALID")) {
      return "邀请码无效、已过期或已被用完。";
    }

    if (errorMessage.includes("PROFILE_ALREADY_EXISTS")) {
      return "这个账号已经创建过个人资料，请直接登录。";
    }

    if (errorMessage.includes("DISPLAY_NAME_INVALID")) {
      return "用户名需要填写，且不能超过 60 个字符。";
    }

    if (errorMessage.includes("USERNAME_INVALID")) {
      return getUsernameHelpText();
    }

    if (errorMessage.includes("USERNAME_ALREADY_EXISTS")) {
      return "这个用户名已经被使用，请换一个。";
    }

    if (errorMessage.includes("AUTH_REQUIRED")) {
      return "注册会话无效，请重新注册或登录后再试。";
    }

    if (
      errorMessage.toLowerCase().includes("already registered") ||
      errorMessage.toLowerCase().includes("already exists")
    ) {
      return "这个用户名可能已经注册，请直接登录或换一个用户名。";
    }

    if (
      errorMessage.toLowerCase().includes("rate limit") ||
      errorMessage.includes("429")
    ) {
      return "注册太频繁，请稍后再试。";
    }

    if (
      errorMessage.toLowerCase().includes("invalid email") ||
      errorMessage.toLowerCase().includes("email address") ||
      errorMessage.toLowerCase().includes("invalid")
    ) {
      return "用户名未通过校验，请使用 3-24 位小写字母、数字或下划线。";
    }

    return "注册失败，请检查用户名、密码和邀请码后再试。";
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    showMessage("正在注册...");

    const formData = new FormData(form);
    const username = normalizeUsername(String(formData.get("username") ?? ""));
    const password = String(formData.get("password") ?? "");
    const inviteCode = String(formData.get("inviteCode") ?? "").trim();
    const authEmail = usernameToAuthEmail(username);

    if (!username || !password || !inviteCode) {
      showMessage("请填写用户名、密码和邀请码。");
      return;
    }

    if (!isValidUsername(username)) {
      showMessage(getUsernameHelpText());
      return;
    }

    try {
      const supabase = createSupabaseBrowserClient();
      const {
        data: { session: currentSession },
      } = await supabase.auth.getSession();
      let activeSession =
        currentSession?.user.email?.toLowerCase() === authEmail
          ? currentSession
          : null;

      if (currentSession && !activeSession) {
        const { error: signOutError } = await supabase.auth.signOut();

        if (signOutError) {
          showMessage("当前已有其他账号登录，请先退出后再注册。");
          return;
        }
      }

      if (!activeSession) {
        const { data, error: signUpError } = await supabase.auth.signUp({
          email: authEmail,
          password,
          options: {
            data: {
              username,
              display_name: username,
            },
          },
        });

        if (signUpError) {
          showMessage(getRegisterError(signUpError.message));
          return;
        }

        activeSession = data.session;
      }

      if (!activeSession) {
        showMessage(
          "当前后台仍开启了邮箱确认，用户名注册无法立即完成。请先关闭邮箱确认后再重新注册。",
        );
        return;
      }

      const { error: profileError } = await supabase.rpc(
        "create_profile_with_invite",
        {
          invite_code: inviteCode,
          username,
          display_name: username,
          avatar_url: null,
        },
      );

      if (profileError) {
        showMessage(getRegisterError(profileError.message));
        return;
      }

      window.location.assign("/dashboard/");
    } catch (error) {
      showMessage(
        error instanceof Error
          ? getRegisterError(error.message)
          : "注册失败，请稍后再试。",
      );
    }
  });
</script>
