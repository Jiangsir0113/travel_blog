---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { TripCardTrip } from "../../components/trips/TripCard.astro";
import { getSessionProfile } from "../../lib/auth";

export const prerender = false;

const { supabase, user, profile } = await getSessionProfile(Astro);

if (!user || !profile) {
  return Astro.redirect(`/auth/login/?next=${encodeURIComponent(Astro.url.pathname)}`, 302);
}

let destinations: Array<[string, TripCardTrip[]]> = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabase
    .from("trips")
    .select("id, slug, title, summary, destination_name, visited_at, province, city, status")
    .eq("status", "published")
    .order("published_at", { ascending: false, nullsFirst: false });

  if (error) {
    loadError = "目的地读取失败，请稍后再试。";
  } else {
    destinations = Array.from(
      (data ?? [])
        .reduce((map, trip) => {
          const current = map.get(trip.destination_name) ?? [];
          current.push(trip);
          map.set(trip.destination_name, current);
          return map;
        }, new Map<string, TripCardTrip[]>())
        .entries(),
    ).sort(([a], [b]) => a.localeCompare(b, "zh-CN"));
  }
} catch {
  loadError = "数据源尚未配置，暂时无法加载目的地。";
}
---

<BaseLayout title="目的地 - 旅行共写小站" description="按目的地整理旅行游记。">
  <section class="hero">
    <div>
      <p class="eyebrow">目的地</p>
      <h1>按地点重新打开旅程。</h1>
      <p class="lead">这里会逐步沉淀成目的地合集、照片索引和地图入口。</p>
    </div>
  </section>

  <section class="section" aria-labelledby="destination-list">
    <h2 id="destination-list">全部目的地</h2>
    {loadError && <p class="meta" role="alert">{loadError}</p>}
    {
      !loadError && destinations.length > 0 ? (
        <div class="grid">
          {destinations.map(([destination, entries]) => (
            <article class="card">
              <p class="meta">{entries.length} 篇游记</p>
              <h3>{destination}</h3>
              <p>{entries[0].summary ?? "还没有摘要。"}</p>
              <a href={`/trips/${entries[0].slug}/`}>阅读最近一篇</a>
            </article>
          ))}
        </div>
      ) : (
        !loadError && <p class="meta">还没有目的地。</p>
      )
    }
  </section>
</BaseLayout>
