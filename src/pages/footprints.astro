---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout title="足迹图 - 旅行共写小站" description="查看朋友们共同记录的旅行城市足迹。">
  <section class="section">
    <p class="eyebrow">足迹图</p>
    <h1>城市足迹图即将上线</h1>
    <p class="lead">下一步会把已发布游记按城市聚合到地图上，展示朋友们一起走过的地方。</p>
    <div class="button-row">
      <a class="button" href="/trips/">先看公开游记</a>
      <a class="button secondary" href="/">返回首页</a>
    </div>
  </section>
</BaseLayout>
