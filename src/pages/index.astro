---
import BaseLayout from "../layouts/BaseLayout.astro";
import TripCard, { type TripCardTrip } from "../components/trips/TripCard.astro";
import { createSupabaseServerClient } from "../lib/supabase/server";

export const prerender = false;

let recentTrips: TripCardTrip[] = [];
let loadError: string | null = null;

try {
  const supabase = createSupabaseServerClient(Astro);
  const { data, error } = await supabase
    .from("trips")
    .select("id, slug, title, summary, destination_name, visited_at, province, city, status")
    .eq("status", "published")
    .order("published_at", { ascending: false, nullsFirst: false })
    .limit(3);

  if (error) {
    loadError = "最新游记读取失败，请稍后再试。";
  } else {
    recentTrips = data ?? [];
  }
} catch {
  loadError = "Supabase 尚未配置，暂时无法加载最新游记。";
}
---

<BaseLayout
  title="旅行共写小站"
  description="和朋友一起记录旅行、照片和足迹的共写小站。"
>
  <section class="hero">
    <div>
      <p class="eyebrow">旅行共写</p>
      <h1>把走过的地方，整理成可以一起回看的故事。</h1>
      <p class="lead">
        从公开游记开始阅读，也可以进入足迹图，把城市、路线和照片连成更完整的旅行记忆。
      </p>
      <div class="button-row">
        <a class="button" href="/trips/">浏览游记</a>
        <a class="button secondary" href="/footprints/">查看足迹图</a>
      </div>
    </div>
    <div class="hero-image">
      <img src="/images/sample-trip.svg" alt="山脉、河流和旅行路线标记组成的示意图" />
    </div>
  </section>

  <section class="section" aria-labelledby="recent-trips">
    <h2 id="recent-trips">最新游记</h2>
    {loadError && <p class="meta" role="alert">{loadError}</p>}
    {
      !loadError && recentTrips.length > 0 ? (
        <div class="grid">
          {recentTrips.map((trip) => (
            <TripCard trip={trip} mode="public" />
          ))}
        </div>
      ) : (
        !loadError && <p class="meta">还没有发布的游记。</p>
      )
    }
  </section>

  <section class="section" aria-labelledby="public-entry">
    <h2 id="public-entry">入口</h2>
    <div class="grid">
      <article class="card">
        <p class="meta">游记列表</p>
        <h3><a href="/trips/">阅读全部公开游记</a></h3>
        <p>按发布时间倒序查看已经发布的旅行故事。</p>
      </article>
      <article class="card">
        <p class="meta">足迹图</p>
        <h3><a href="/footprints/">打开旅行足迹图</a></h3>
        <p>从地图视角回看目的地、城市和路线。</p>
      </article>
    </div>
  </section>
</BaseLayout>
