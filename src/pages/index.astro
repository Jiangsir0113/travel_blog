---
import BaseLayout from "../layouts/BaseLayout.astro";
import TripCard, { type TripCardTrip } from "../components/trips/TripCard.astro";
import { getSessionProfile } from "../lib/auth";

export const prerender = false;

const { supabase, user, profile } = await getSessionProfile(Astro);

if (!user || !profile) {
  return Astro.redirect(`/auth/login/?next=${encodeURIComponent(Astro.url.pathname)}`, 302);
}

let recentTrips: TripCardTrip[] = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabase
    .from("trips")
    .select("id, slug, title, summary, destination_name, visited_at, province, city, status")
    .eq("status", "published")
    .order("published_at", { ascending: false, nullsFirst: false })
    .limit(3);

  if (error) {
    loadError = "最新游记读取失败，请稍后再试。";
  } else {
    recentTrips = data ?? [];
  }
} catch {
  loadError = "数据源尚未配置，暂时无法加载最新游记。";
}
---

<BaseLayout
  title="旅行共写小站"
  description="和朋友一起记录旅行、照片和足迹的共写小站。"
>
  <section class="hero">
    <div>
      <p class="eyebrow">旅行共写小站</p>
      <h1>把朋友们走过的地方，写成可以一起回看的故事。</h1>
      <p class="lead">
        从成员游记开始阅读，也可以进入足迹图，把城市、路线、照片和同行人的片段连成更完整的旅行记忆。
      </p>
      <div class="hero-note-list" aria-label="小站能力">
        <span>成员可见</span>
        <span>省市足迹</span>
        <span>照片游记</span>
      </div>
      <div class="button-row">
        <a class="button" href="/trips/">浏览游记</a>
        <a class="button secondary" href="/footprints/">查看足迹图</a>
      </div>
    </div>
    <div class="hero-image">
      <img src="/images/travel-collab-hero.svg" alt="朋友共同记录旅行足迹、照片和路线的插画" />
    </div>
  </section>

  <section class="section" aria-labelledby="recent-trips">
    <h2 id="recent-trips">最新游记</h2>
    {loadError && <p class="meta" role="alert">{loadError}</p>}
    {
      !loadError && recentTrips.length > 0 ? (
        <div class="grid">
          {recentTrips.map((trip) => (
            <TripCard trip={trip} mode="public" />
          ))}
        </div>
      ) : (
        !loadError && <p class="meta">还没有发布的游记。</p>
      )
    }
  </section>

  <section class="section" aria-labelledby="public-entry">
    <h2 id="public-entry">入口</h2>
    <div class="grid">
      <article class="card">
        <p class="meta">游记列表</p>
        <h3><a href="/trips/">阅读全部成员游记</a></h3>
        <p>按发布时间倒序查看已经发布的旅行故事。</p>
      </article>
      <article class="card">
        <p class="meta">足迹图</p>
        <h3><a href="/footprints/">打开旅行足迹图</a></h3>
        <p>从地图视角回看目的地、城市和路线。</p>
      </article>
    </div>
  </section>
</BaseLayout>
